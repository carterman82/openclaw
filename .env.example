# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Anthropic API key for the openclaw agent's article generator (Claude).
# Starts with `sk-ant-`.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# WordPress site base URL (no trailing slash).
WP_BASE_URL=http://localhost:8088

# WordPress user the agent posts as. Must have at least the Author role.
WP_USERNAME=openclaw-agent

# Application Password generated for WP_USERNAME via wp-admin or
# `wp user application-password create <user> <name>`.
# 24 characters; WP accepts the password with or without spaces.
WP_APP_PASSWORD=REPLACE_ME

# Optional — only needed if you flip the agent back to the (currently
# commented-out) GPT-4o path in openclaw/generator.py. Starts with `sk-`.
# OPENAI_API_KEY=sk-REPLACE_ME
