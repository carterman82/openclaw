# Copy this file to `.env` and fill in real values. Never commit `.env`.

# =========================================================================
# Cross-site keys — used regardless of which WordPress site is active.
# =========================================================================

# Anthropic API key for the openclaw agent's article generator (Claude).
# Starts with `sk-ant-`.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Unsplash API access key for Phase 3 featured images.
# Free at https://unsplash.com/developers — register an application named
# `openclaw` (the name appears in attribution UTM params). If unset, the
# agent publishes without featured images and logs a warning.
UNSPLASH_ACCESS_KEY=REPLACE_ME

# OpenAI API key for Phase 3 featured-image generation (gpt-image-2).
# Required to generate featured images; if unset, articles publish without
# them. Also reused if you flip the agent back to the (commented-out) GPT-4o
# text path in openclaw/generator.py. Starts with `sk-`.
OPENAI_API_KEY=sk-REPLACE_ME

# =========================================================================
# Per-site WordPress credentials (Phase 3.6 multi-site support).
# =========================================================================
# Pattern: {SLUG}_WP_BASE_URL, {SLUG}_WP_USERNAME, {SLUG}_WP_APP_PASSWORD.
# Select the active site at the CLI with `--site <slug>` (lowercase).
# Each site also needs a website_memory/{hostname}.md persona file.

# Example: catfancast.com
# CATFANCAST_WP_BASE_URL=https://catfancast.com
# CATFANCAST_WP_USERNAME=openclaw-agent
# CATFANCAST_WP_APP_PASSWORD=REPLACE_ME
# → invoke as: python -m openclaw post --site catfancast

# Example: a second site
# OTHERSITE_WP_BASE_URL=https://othersite.com
# OTHERSITE_WP_USERNAME=openclaw-agent
# OTHERSITE_WP_APP_PASSWORD=REPLACE_ME

# =========================================================================
# Single-site fallback — bare WP_* env vars.
# =========================================================================
# Used when `--site` is omitted. Fine for local dev against Docker or for
# a single production site. Ignored when `--site <slug>` is passed.

# WordPress site base URL (no trailing slash).
WP_BASE_URL=http://localhost:8088

# WordPress user the agent posts as. Must have at least the Author role.
WP_USERNAME=openclaw-agent

# Application Password generated for WP_USERNAME via wp-admin or
# `wp user application-password create <user> <name>`.
# 24 characters; WP accepts the password with or without spaces.
WP_APP_PASSWORD=REPLACE_ME
