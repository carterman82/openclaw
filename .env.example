# Copy this file to `.env` and fill in real values. Never commit `.env`.

# =========================================================================
# Cross-site keys — used regardless of which WordPress site is active.
# =========================================================================

# Anthropic API key for the openclaw agent's article generator (Claude).
# Starts with `sk-ant-`.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Unsplash API access key for Phase 3 featured images.
# Free at https://unsplash.com/developers — register an application named
# `openclaw` (the name appears in attribution UTM params). If unset, the
# agent publishes without featured images and logs a warning.
UNSPLASH_ACCESS_KEY=REPLACE_ME

# OpenAI API key for Phase 3 featured-image generation (gpt-image-2).
# Required to generate featured images; if unset, articles publish without
# them. Also reused if you flip the agent back to the (commented-out) GPT-4o
# text path in openclaw/generator.py. Starts with `sk-`.
OPENAI_API_KEY=sk-REPLACE_ME

# Phase 3.8 local-model provider (LM Studio / any OpenAI-compatible server).
# When LOCAL_MODEL_ENABLED=true, generator.generate_article() tries the local
# model first and falls back to Claude on any error. When unset or false, the
# agent uses Claude directly (pre-3.8 behavior).
# LOCAL_MODEL_BASE_URL must include the /v1 suffix — the openai SDK appends
# /chat/completions to it.
# LOCAL_MODEL_ENABLED=true
# LOCAL_MODEL_BASE_URL=http://192.168.0.200:1234/v1
# LOCAL_MODEL_NAME=qwen/qwen3.6-35b-a3b

# Step 3.8.7 inference-tuning knobs for the local model. All optional; the
# commented values below are also the code defaults. Qwen3's hybrid
# reasoning mode burns part (sometimes ALL) of the completion budget on a
# <think> trace before emitting the tool call, so LOCAL_MODEL_MAX_TOKENS
# defaults to a generous 12000 across all three call sites (subreddit_select
# previously hardcoded a much smaller 2048, which guaranteed failure).
# LOCAL_MODEL_DISABLE_THINKING defaults to FALSE: Step 3.8.5 found that
# extra_body={"reasoning_effort":"none"} does suppress the <think> trace on
# this LM Studio build, but also reliably breaks tool_choice="required"
# grammar enforcement (the model answers in prose instead of calling the
# tool) - net harmful here. It's left as an opt-in escape hatch in case a
# future LM Studio/model build handles it without that side effect.
# LOCAL_MODEL_TEMPERATURE=0.2
# LOCAL_MODEL_TOP_P=0.9
# LOCAL_MODEL_MAX_TOKENS=12000
# LOCAL_MODEL_DISABLE_THINKING=false

# Phase 3.9 local image provider (Flux via the Draw Things app HTTP API).
# When LOCAL_IMAGE_ENABLED=true, featured-image generation tries Draw Things
# first and falls back to OpenAI, then Unsplash, on any failure. When unset
# or false, behavior is unchanged (OpenAI then Unsplash).
# LOCAL_IMAGE_ENABLED=true
# LOCAL_IMAGE_BASE_URL=http://192.168.0.200:7860

# =========================================================================
# Per-site WordPress credentials (Phase 3.6 multi-site support).
# =========================================================================
# Pattern: {SLUG}_WP_BASE_URL, {SLUG}_WP_USERNAME, {SLUG}_WP_APP_PASSWORD.
# Select the active site at the CLI with `--site <slug>` (lowercase).
# Each site also needs a website_memory/{hostname}.md persona file.

# Example: catfancast.com
# CATFANCAST_WP_BASE_URL=https://catfancast.com
# CATFANCAST_WP_USERNAME=openclaw-agent
# CATFANCAST_WP_APP_PASSWORD=REPLACE_ME
# → invoke as: python -m openclaw post --site catfancast

# Example: a second site
# OTHERSITE_WP_BASE_URL=https://othersite.com
# OTHERSITE_WP_USERNAME=openclaw-agent
# OTHERSITE_WP_APP_PASSWORD=REPLACE_ME

# Phase 5 pilot subsites (local Docker WP multisite network at *.localhost:8088).
# openclaw-agent is a super_admin on the network, so all four subsites share the
# same app password. Browsers resolve *.localhost to 127.0.0.1 natively (RFC 6761),
# so no hosts-file edit is required.
# GARDENING_WP_BASE_URL=http://gardening.localhost:8088
# GARDENING_WP_USERNAME=openclaw-agent
# GARDENING_WP_APP_PASSWORD=REPLACE_ME
# DOGS_WP_BASE_URL=http://dogs.localhost:8088
# DOGS_WP_USERNAME=openclaw-agent
# DOGS_WP_APP_PASSWORD=REPLACE_ME
# BOARDGAMES_WP_BASE_URL=http://boardgames.localhost:8088
# BOARDGAMES_WP_USERNAME=openclaw-agent
# BOARDGAMES_WP_APP_PASSWORD=REPLACE_ME
# COFFEE_WP_BASE_URL=http://coffee.localhost:8088
# COFFEE_WP_USERNAME=openclaw-agent
# COFFEE_WP_APP_PASSWORD=REPLACE_ME

# =========================================================================
# Single-site fallback — bare WP_* env vars.
# =========================================================================
# Used when `--site` is omitted. Fine for local dev against Docker or for
# a single production site. Ignored when `--site <slug>` is passed.

# WordPress site base URL (no trailing slash).
WP_BASE_URL=http://localhost:8088

# WordPress user the agent posts as. Must have at least the Author role.
WP_USERNAME=openclaw-agent

# Application Password generated for WP_USERNAME via wp-admin or
# `wp user application-password create <user> <name>`.
# 24 characters; WP accepts the password with or without spaces.
WP_APP_PASSWORD=REPLACE_ME
