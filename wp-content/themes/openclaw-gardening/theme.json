{
    "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
    "version": 3,
    "settings": {
        "typography": {
            "fontFamilies": [
                {
                    "name": "Body",
                    "slug": "openclaw-body",
                    "fontFamily": "'Lora', Georgia, 'Times New Roman', serif"
                },
                {
                    "name": "Display",
                    "slug": "openclaw-display",
                    "fontFamily": "'Fraunces', 'Lora', Georgia, serif"
                }
            ]
        },
        "color": {
            "palette": [
                { "name": "Background", "slug": "openclaw-background", "color": "#FBF7EE" },
                { "name": "Surface",    "slug": "openclaw-surface",    "color": "#EFEBDB" },
                { "name": "Text",       "slug": "openclaw-text",       "color": "#1F2E1A" },
                { "name": "Muted",      "slug": "openclaw-muted",      "color": "#6B7566" },
                { "name": "Primary",    "slug": "openclaw-primary",    "color": "#3B5F3A" },
                { "name": "Accent",     "slug": "openclaw-accent",     "color": "#B0552C" }
            ]
        }
    }
}
