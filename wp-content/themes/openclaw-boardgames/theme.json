{
    "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
    "version": 3,
    "settings": {
        "typography": {
            "fontFamilies": [
                {
                    "name": "Body",
                    "slug": "openclaw-body",
                    "fontFamily": "'Work Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif"
                },
                {
                    "name": "Display",
                    "slug": "openclaw-display",
                    "fontFamily": "'Roboto Slab', 'Work Sans', Georgia, serif"
                }
            ]
        },
        "color": {
            "palette": [
                { "name": "Background", "slug": "openclaw-background", "color": "#F3E9D4" },
                { "name": "Surface",    "slug": "openclaw-surface",    "color": "#EBDFC1" },
                { "name": "Text",       "slug": "openclaw-text",       "color": "#1B1A17" },
                { "name": "Muted",      "slug": "openclaw-muted",      "color": "#6A6558" },
                { "name": "Primary",    "slug": "openclaw-primary",    "color": "#2A5B60" },
                { "name": "Accent",     "slug": "openclaw-accent",     "color": "#E0A93D" }
            ]
        }
    }
}
