{
    "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
    "version": 3,
    "settings": {
        "typography": {
            "fontFamilies": [
                {
                    "name": "Body",
                    "slug": "openclaw-body",
                    "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif"
                },
                {
                    "name": "Display",
                    "slug": "openclaw-display",
                    "fontFamily": "'Cormorant Garamond', 'Cormorant', Garamond, Georgia, serif"
                }
            ]
        },
        "color": {
            "palette": [
                { "name": "Background", "slug": "openclaw-background", "color": "#FBF6EB" },
                { "name": "Surface",    "slug": "openclaw-surface",    "color": "#F2E9D9" },
                { "name": "Text",       "slug": "openclaw-text",       "color": "#2A1B10" },
                { "name": "Muted",      "slug": "openclaw-muted",      "color": "#7B6753" },
                { "name": "Primary",    "slug": "openclaw-primary",    "color": "#5C3B21" },
                { "name": "Accent",     "slug": "openclaw-accent",     "color": "#B08D42" }
            ]
        }
    }
}
