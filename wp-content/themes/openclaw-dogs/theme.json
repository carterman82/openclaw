{
    "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
    "version": 3,
    "settings": {
        "typography": {
            "fontFamilies": [
                {
                    "name": "Body",
                    "slug": "openclaw-body",
                    "fontFamily": "'Nunito Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif"
                },
                {
                    "name": "Display",
                    "slug": "openclaw-display",
                    "fontFamily": "'Domine', 'Nunito Sans', Georgia, serif"
                }
            ]
        },
        "color": {
            "palette": [
                { "name": "Background", "slug": "openclaw-background", "color": "#FBF8F4" },
                { "name": "Surface",    "slug": "openclaw-surface",    "color": "#F0E7D8" },
                { "name": "Text",       "slug": "openclaw-text",       "color": "#2A1F17" },
                { "name": "Muted",      "slug": "openclaw-muted",      "color": "#8B7B6A" },
                { "name": "Primary",    "slug": "openclaw-primary",    "color": "#6E4A2C" },
                { "name": "Accent",     "slug": "openclaw-accent",     "color": "#D9A038" }
            ]
        }
    }
}
